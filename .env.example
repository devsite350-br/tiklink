# ============================================================================
# Simpofy CRM — Standalone environment variables
# Copy to .env.local for local dev, and set the same values in Vercel
# (Project → Settings → Environment Variables) for production.
# ============================================================================

# ── Frontend (PUBLIC, build-time) — Firebase Web config ─────────────────────
# Firebase Console → Project settings → Your apps → SDK setup and configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: absolute base URL for the API (leave empty to use the same origin).
VITE_API_BASE=

# Optional: webhook secret embedded in the lead/WhatsApp webhook URLs shown in
# the UI. MUST equal the backend WEBHOOK_SECRET below. Leave empty to disable.
VITE_WEBHOOK_SECRET=

# Super-admin email. When the signed-in user's email matches this value, they
# get the account-management screen and can impersonate ("log in as") any owner
# account. Leave empty to disable the admin panel entirely. Must also match the
# super-admin email hardcoded in firestore.rules.
VITE_SUPER_ADMIN_EMAIL=

# ── Backend (SECRET, Vercel server-side only) ───────────────────────────────
# Firebase service account JSON, base64-encoded (recommended). Generate it in
# Firebase Console → Project settings → Service accounts → Generate new private
# key, then: base64 -w0 serviceAccount.json
FIREBASE_SERVICE_ACCOUNT=

# Google Cloud OAuth client (Gmail + Calendar). Google Cloud Console →
# APIs & Services → Credentials → OAuth 2.0 Client ID (Web application).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Optional explicit redirect (usually the frontend passes it at runtime).
GOOGLE_OAUTH_REDIRECT_URI=

# Resend — fallback email provider (https://resend.com). Optional if you only
# use Gmail/SMTP per user.
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Secret used to derive the AES key that encrypts per-user Gemini API keys.
# Use a long random string (e.g. openssl rand -hex 32). Do NOT change it after
# users have saved keys, or saved keys can no longer be decrypted.
APP_ENCRYPTION_KEY=

# Shared secret required on public webhooks (leads / tasks / whatsapp inbound).
# Must equal VITE_WEBHOOK_SECRET. Leave empty to disable the check.
WEBHOOK_SECRET=

# Optional: the owner account UID. When set, public webhooks reject any other
# userId. Recommended for a single-customer deployment.
OWNER_UID=

# Vercel Blob — set automatically by Vercel when you connect a Blob store to
# the project (Storage → Create → Blob → Connect to Project). No manual setup
# needed. The SDK uses BLOB_STORE_ID + Vercel OIDC for authentication.
# BLOB_STORE_ID=          (auto-injected by Vercel)
# BLOB_WEBHOOK_PUBLIC_KEY= (auto-injected by Vercel)
